{
    "env": {
        "CLAUDE_CODE_SUBAGENT_MODEL": "opus"
    },
    "permissions": {
        "defaultMode": "acceptEdits",
        "allow": [
            "WebFetch(domain:*)",
            "WebSearch",
            "Read",
            "Bash"
        ],
        "deny": [
            "Bash(rm:*)",
            "Bash(rmdir:*)"
        ],
        "ask": [
            "Bash(shred:*)",
            "Bash(unlink:*)",
            "Bash(dd:*)",
            "Bash(mkfs:*)",
            "Bash(fdisk:*)",
            "Bash(chmod:*)",
            "Bash(chown:*)",
            "Bash(docker:*)",
            "Bash(kubectl:*)",
            "Bash(firebase:*)",
            "Bash(gcloud:*)",
            "Bash(wget:*)",
            "Bash(kill:*)",
            "Bash(killall:*)",
            "Bash(pkill:*)"
        ]
    },
    "model": "opus[1m]",
    "alwaysThinkingEnabled": true,
    "effortLevel": "max",
    "statusLine": {
        "type": "command",
        "command": "~/.claude-internal/statusline.sh"
    },
    "enabledPlugins": {
        "claude-code-internal@claude-code-internal-plugins": true,
        "gopls-lsp@claude-plugins-official": true
    },
    "language": "简体中文",
    "editorMode": "normal",
    "verbose": true,
    "preferredNotifChannel": "auto"
}