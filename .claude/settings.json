{
    "permissions": {
        "defaultMode": "acceptEdits",
        "allow": [
            "WebFetch(domain:*)",
            "WebSearch",
            "Read(//**)",
            "Bash(ls:*)",
            "Bash(find:*)",
            "Bash(wc:*)",
            "Bash(pwd:*)",
            "Bash(cat:*)",
            "Bash(awk:*)",
            "Bash(grep:*)",
            "Bash(go build:*)",
            "Bash(go test:*)",
            "Bash(go vet:*)",
            "Bash(go mod tidy:*)",
            "Bash(go run:*)",
            "Bash(go fmt:*)",
            "Bash(go env:*)",
            "Bash(GOMODCACHE:*)"
        ],
        "deny": [
            "Bash(rm *)",
            "Bash(rmdir *)"
        ],
        "ask": [
            "Bash(shred *)",
            "Bash(unlink *)",
            "Bash(dd *)",
            "Bash(mkfs *)",
            "Bash(fdisk *)",
            "Bash(chmod *)",
            "Bash(chown *)",
            "Bash(npm *)",
            "Bash(pip *)",
            "Bash(pip3 *)",
            "Bash(yarn *)",
            "Bash(pnpm *)",
            "Bash(docker *)",
            "Bash(kubectl *)",
            "Bash(firebase *)",
            "Bash(gcloud *)",
            "Bash(wget *)",
            "Bash(kill *)",
            "Bash(killall *)",
            "Bash(pkill *)"
        ]
    },
    "model": "opus[1m]",
    "env": {
        "CLAUDE_CODE_SUBAGENT_MODEL": "opus"
    },
    "enabledPlugins": {
        "claude-code-internal@claude-code-internal-plugins": true,
        "gopls-lsp@claude-plugins-official": true
    },
    "language": "简体中文",
    "statusLine": {
        "type": "command",
        "command": "~/.claude-internal/statusline.sh"
    }
}